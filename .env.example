# Copy to `.env.local` (do not commit real keys).

# --- Option A: OpenAI-compatible API (no Google; good for CN-friendly providers) ---
# DeepSeek: https://platform.deepseek.com
#   VITE_OPENAI_COMPAT_BASE_URL=https://api.deepseek.com/v1
#   VITE_OPENAI_COMPAT_MODEL=deepseek-chat
# SiliconFlow / 其他：填对方文档里的 base URL（通常以 /v1 结尾）与模型名
# OpenRouter: https://openrouter.ai — base 一般为 https://openrouter.ai/api/v1
VITE_OPENAI_COMPAT_API_KEY=
VITE_OPENAI_COMPAT_BASE_URL=
VITE_OPENAI_COMPAT_MODEL=deepseek-chat

# --- Option B: Google Gemini (needs key from AI Studio if available in your region) ---
# https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=

# --- Option C: Volcengine Doubao Seedream (text-to-image for comic) ---
# Ark console API key: https://console.volcengine.com/ark
# Base usually: https://ark.cn-beijing.volces.com/api/v3
VITE_DOUBAO_API_KEY=
VITE_DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
VITE_DOUBAO_SEEDREAM_MODEL=doubao-seedream-4-0-250828
